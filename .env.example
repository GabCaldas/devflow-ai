# LLM providers (free tier)
# Groq key:   https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini key (fallback): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# preferred provider: groq | gemini
LLM_PROVIDER=groq

# GitHub Personal Access Token: https://github.com/settings/tokens
GITHUB_TOKEN=

# Local, dependency-free Code RAG. Point this to the repository being analyzed.
RAG_ENABLED=true
CODEBASE_PATH=.
RAG_TOP_K=5
RAG_MAX_FILES=1500
RAG_MAX_CONTEXT_CHARS=7000

# Langfuse (LLM observability): https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
