# ===== Provedores LLM (free tier) =====
# Groq (principal) -> https://console.groq.com/keys  (gratuito, sem cartao)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (fallback) -> https://aistudio.google.com/app/apikey  (gratuito)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Provedor preferido: groq | gemini
LLM_PROVIDER=groq

# ===== GitHub (integracao com Pull Requests) =====
# Token pessoal (PAT) -> https://github.com/settings/tokens
# Para repos publicos: escopo "public_repo". Privados: "repo".
GITHUB_TOKEN=
